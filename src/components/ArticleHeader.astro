---
const { frontmatter } = Astro.props;
const heroImageSrc =
    frontmatter.heroImage
        ? (typeof frontmatter.heroImage === "object" && frontmatter.heroImage !== null
            ? frontmatter.heroImage.src
            : frontmatter.heroImage)
        : null;
---

<header
    class:list={[
        "relative w-full flex flex-col justify-center items-center overflow-hidden",
        heroImageSrc ? "h-screen min-h-[800px]" : "py-32"
    ]}
>
    <!-- Background Image with Overlay -->
    {heroImageSrc && (
        <div class="absolute inset-0 z-0 bg-black">
            <div
                class="w-full h-full bg-cover bg-center opacity-60"
                style={`background-image: url('${heroImageSrc}');`}
            >
            </div>
            <!-- Dark gradient overlay for better text readability -->
            <div class="absolute inset-0 bg-gradient-to-t from-black via-black/40 to-black/60"></div>
        </div>
    )}

    <!-- Hero Content -->
    <div class="relative z-30 text-center px-4 max-w-7xl mx-auto mt-20">
        <h1
            class="text-[clamp(2rem,12vw,6rem)] leading-[0.85] font-bold text-surface break-words tracking-tighter text-shadow-(--color-primary)"
            set:html={frontmatter.title}
        >
        </h1>
        <div
            class="mt-6 flex justify-center items-center gap-4 text-xs font-bold tracking-[0.2em] text-surface/80 uppercase"
        >
            <div
                class="inline-block md:p-4 p-2 md:text-sm text-xs"
            >
                <span>{new Date(frontmatter.date).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" })}</span>
                <span class="w-1 h-1 text-primary rounded-full">●</span>
                <span>Por {frontmatter.author}</span>
            </div>
        </div>
    </div>

    <!-- Scroll Indicator -->
    {heroImageSrc && (
        <div
            class="absolute bottom-10 left-1/2 -translate-x-1/2 z-30 animate-bounce"
        >
            <span class="material-symbols-outlined text-4xl text-surface">
                <svg
                    xmlns="http://www.w3.org/2000/svg"
                    width="24"
                    height="24"
                    viewBox="0 0 24 24"
                    fill="none"
                    stroke="currentColor"
                    stroke-width="2"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    class="icon icon-tabler icons-tabler-outline icon-tabler-arrow-down"
                    ><path stroke="none" d="M0 0h24v24H0z" fill="none"></path><path
                        d="M12 5l0 14"></path><path d="M18 13l-6 6"></path><path
                        d="M6 13l6 6"></path>
                </svg>
            </span>
        </div>
    )}
</header>
