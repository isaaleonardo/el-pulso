---
const { src, alt, title } = Astro.props;

const imageSrc = typeof src === "object" && src !== null ? src.src : src;
const caption = title || alt || "Figure";
---

<div class="my-24 grid grid-cols-1 gap-4 max-w-4xl mx-auto -rotate-1 not-prose">
    <figure class="relative group overflow-hidden">
        <div
            class="absolute inset-0 group-hover:bg-transparent transition-colors duration-500 z-10"
        >
        </div>
        <img
            alt={alt}
            class="w-full h-[400px] object-cover transition-transform duration-700"
            src={imageSrc}
        />
        {
            caption && (
                <figcaption class="py-1 text-xs font-bold text-white tracking-widest">
                    {caption}
                </figcaption>
            )
        }
    </figure>
</div>
