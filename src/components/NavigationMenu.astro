<style>
    /* Custom texture mask effect for hover */
    .nav-link {
        -webkit-text-stroke: 1px rgba(255, 255, 255, 0.2);
        color: transparent;
        transition: all 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        position: relative;
    }

    .nav-link::before {
        content: attr(data-text);
        position: absolute;
        left: 0;
        top: 0;
        width: 0%;
        height: 100%;
        color: var(--color-primary, #b72a1a); /* Primary color fill */
        overflow: hidden;
        transition: width 0.4s cubic-bezier(0.19, 1, 0.22, 1);
        white-space: nowrap;
         /* Simulate texture with a subtle gradient */
        background: linear-gradient(45deg, var(--color-primary, #b72a1a), #ff4d3b);
        -webkit-background-clip: text;
        background-clip: text;
        -webkit-text-fill-color: transparent;
    }

    .nav-link:hover {
        -webkit-text-stroke: 1px rgba(183, 42, 26, 0.5); /* using primary roughly */
    }

    .nav-link:hover::before {
        width: 100%;
    }

    /* 3D Transform simulation for "Open" state */
    .perspective-container {
        perspective: 1000px;
    }
    
    /* Custom scrollbar for brutalist feel */
    ::-webkit-scrollbar {
        width: 8px;
    }
    ::-webkit-scrollbar-track {
        background: var(--color-background-dark, #211311); 
    }
    ::-webkit-scrollbar-thumb {
        background: var(--color-primary, #b72a1a); 
    }
</style>

