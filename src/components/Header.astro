---
import { Image } from "astro:assets";
import logoImage from "@/assets/images/logos/ElPulso_Monogram_Red.png";

const pathname = Astro.url.pathname;
const isHome = pathname === '/' || pathname === '';
---

<header class="sticky top-0 z-40 w-full bg-background-dark border-b border-gray-800">
    <nav
        class="px-10 py-4 flex justify-between items-center text-white"
    >
        <a href="/" class="group">
            <div class="flex items-center gap-2">
                <Image src={logoImage} alt="El Pulso" width={50} height={50} />
                {!isHome && (
                    <div class="text-accent text-sm align-top tracking-normal font-normal opacity-0 group-hover:opacity-100 transition-opacity">Ir a la portada</div>
                )}
            </div>
        </a>

        <div class="flex items-center gap-4">
            <!-- Hide search button for now (before implementing search functionality) -->
            <!-- <button class="hidden md:flex items-center justify-center size-10 border border-surface/20 hover:bg-primary hover:border-primary transition-colors rounded-full text-surface">
                <span class="material-symbols-outlined text-xl">search</span>
            </button> -->
    
            <button
                class="group flex items-center gap-2 text-sm font-bold tracking-widest hover:text-primary transition-colors cursor-pointer"
            >
                <span
                    class="material-symbols-outlined text-lg group-hover:rotate-90 transition-transform"
                >
                    <svg
                        xmlns="http://www.w3.org/2000/svg"
                        width="24"
                        height="24"
                        viewBox="0 0 24 24"
                        fill="none"
                        stroke="currentColor"
                        stroke-width="2"
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        class="icon icon-tabler icons-tabler-outline icon-tabler-menu-2"
                        ><path stroke="none" d="M0 0h24v24H0z" fill="none"
                        ></path><path d="M4 6l16 0"></path><path d="M4 12l16 0"
                        ></path><path d="M4 18l16 0"></path>
                    </svg>
                </span>
            </button>
        </div>

    </nav>
</header>
