---
import BaseLayout from "@/layouts/BaseLayout.astro";
import NotaCard from "@/components/NotaCard.astro";
---

<BaseLayout title="El Pulso: Cultura que late">
    <!-- Main Content Area: The Masonry Grid -->
    <main class="flex-grow px-4 md:px-12 py-8 md:py-16 w-full max-w-[1800px] mx-auto">
        <div class="masonry-grid">
            <NotaCard link="/nota/sandro-oramas-tarde-de-musica" />
            <NotaCard link="/nota/concierto-nacidos-de-lo-alto" />
            <NotaCard link="/nota/despecho-teatro-lamas" />
            <NotaCard link="/nota/maya-von-presentacion-en-la-trinidad" />
        </div>

        <!-- Link to Feed page -->
        <div class="mt-16 w-full pb-8">
            <a href="/feed" class="group flex w-full items-center justify-center gap-4 border border-white/20 bg-black py-8 text-xl font-bold uppercase tracking-[0.2em] text-white transition-all duration-300 hover:border-primary hover:bg-primary">
                <span>Ver todas las notas</span>
                <span class="group-hover:hidden">↓</span>
                <span class="hidden group-hover:inline">←</span>
            </a>
        </div>
    </main>
</BaseLayout>
