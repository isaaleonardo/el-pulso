---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TypeACard from "@/components/TypeACard.astro";
import TypeBCard from "@/components/TypeBCard.astro";
import TypeCCard from "@/components/TypeCCard.astro";
import mayaVonImg from "@/assets/images/notas/maya-von-presentacion-en-la-trinidad/1.jpg";
import logo from "@/assets/images/logos/ElPulso_Wordmark_White.png";
---

<BaseLayout title="Home">
    <!-- Main Content Area: The Masonry Grid -->
    <main class="flex-grow px-4 md:px-12 py-8 md:py-16 w-full max-w-[1800px] mx-auto">
        <div class="masonry-grid">
            <!-- Card 1: Type A (Image Lead - Tall) -->
            <TypeACard 
                image={mayaVonImg.src}
                alt="Maya Von se presenta en la Hacienda La Trinidad"
                aspectRatio="aspect-[3/5]"
                category="Música"
                categoryTheme="accent"
                title="Maya Von se presenta en la Hacienda La Trinidad"
                titleClass="text-3xl"
                date="5 de marzo de 2026"
                link="/nota/maya-von-presentacion-en-la-trinidad"
            />

            <!-- Card 2: Type B (Text Lead - Red) -->
            <TypeBCard 
                theme="primary"
                category="Cine"
                title="La Orilla, la primera película de terror hecha en Margarita, se estrena en cines"
                date="1 de marzo de 2026"
                verticalLabel="Rebellion"
                link="/nota/la-orilla-estreno"
            />

            <!-- Card 3: Type C (Text Lead with a button of cta) -->
            <TypeCCard 
                category="Teatro"
                title="El despecho como arquitectura de la cultura de Los Teques"
                description="¿Cómo el despecho puede ser una forma de arquitectura de la cultura de Los Teques?"
                link="/nota/el-despecho-arquitectura"
            />
        </div>
    </main>
</BaseLayout>
