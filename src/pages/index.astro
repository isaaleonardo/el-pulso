---
import BaseLayout from "@/layouts/BaseLayout.astro";
import TypeACard from "@/components/TypeACard.astro";
import TypeBCard from "@/components/TypeBCard.astro";
import TypeCCard from "@/components/TypeCCard.astro";
import mayaVonImg from "@/assets/images/notas/maya-von-presentacion-en-la-trinidad/1.jpg";
import { getCollection } from "astro:content";

const allNotas = await getCollection("notas");
const sortedNotas = allNotas.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
---

<BaseLayout title="El Pulso: Cultura que late">
    <!-- Main Content Area: The Masonry Grid -->
    <main class="flex-grow px-4 md:px-12 py-8 md:py-16 w-full max-w-[1800px] mx-auto">
        <div class="masonry-grid">
            <!-- Card 1: Type A (Image Lead - Tall) -->
            <TypeACard 
                image={mayaVonImg.src}
                alt="Maya Von se presenta en la Hacienda La Trinidad"
                aspectRatio="aspect-[3/5]"
                category="Música"
                categoryTheme="accent"
                title="Maya Von se presenta en la Hacienda La Trinidad"
                titleClass="text-3xl"
                date="5 de marzo de 2026"
                link="/nota/maya-von-presentacion-en-la-trinidad"
            />

            <!-- Card 2: Type B (Text Lead - Red) -->
            <TypeBCard 
                theme="primary"
                category="Cine"
                title="La Orilla, la primera película de terror hecha en Margarita, se estrena en cines"
                date="1 de marzo de 2026"
                verticalLabel="Rebellion"
                link="/nota/la-orilla-estreno"
            />

            <!-- Card 3: Type C (Text Lead with a button of cta) -->
            <TypeCCard 
                category="Teatro"
                title="El despecho como arquitectura de la cultura de Los Teques"
                description="¿Cómo el despecho puede ser una forma de arquitectura de la cultura de Los Teques?"
                link="/nota/el-despecho-arquitectura"
            />
        </div>

        <!-- A feed of the articles ordered by date -->
        <section class="mt-16 border-t-[8px] border-black pt-12">
            <h2 class="text-5xl font-black tracking-tighter uppercase mb-12">Últimas Noticias</h2>
            <div class="flex flex-col divide-y divide-black/20 pb-16">
                {sortedNotas.map(nota => (
                    <article class="py-8 group flex flex-col md:flex-row gap-8 items-start">
                        {nota.data.heroImage && (
                            <a href={`/nota/${nota.slug}`} class="w-full md:w-1/3 shrink-0 overflow-hidden block aspect-[16/9] bg-black/5">
                                <img 
                                    src={typeof nota.data.heroImage === 'string' ? nota.data.heroImage : nota.data.heroImage.src} 
                                    alt={nota.data.heroImageAlt || nota.data.title} 
                                    class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                                />
                            </a>
                        )}
                        <div class="flex flex-col flex-grow text-white">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="px-2 py-1 text-xs uppercase tracking-widest text-surface bg-primary">{nota.data.category}</span>
                                <time datetime={nota.data.date} class="text-sm font-semibold uppercase tracking-widest">
                                    {new Date(nota.data.date).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" })}
                                </time>
                            </div>
                            <h3 class="text-3xl md:text-4xl font-bold leading-none tracking-tight mb-4">
                                <a href={`/nota/${nota.slug}`} class="hover:text-red-600 transition-colors duration-200">
                                    {nota.data.title}
                                </a>
                            </h3>
                            {nota.data.description && (
                                <p class="text-xl font-medium leading-relaxed mb-6">{nota.data.description}</p>
                            )}
                            
                            <div class="mt-auto">
                                <a href={`/nota/${nota.slug}`}><span class="text-sm font-bold uppercase tracking-widest border-b-2 border-transparent group-hover:border-red-600 transition-colors">Leer Más &rarr;</span></a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>
        </section>
    </main>
</BaseLayout>
