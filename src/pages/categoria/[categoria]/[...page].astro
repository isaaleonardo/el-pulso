---
import BaseLayout from "@/layouts/BaseLayout.astro";
import defaultImg from "@/assets/images/notas/default.png";
import { getCollection } from "astro:content";

export async function getStaticPaths({ paginate }) {
    const allNotas = await getCollection("notas");
    
    // Get all unique categories (handling possible missing categories gracefully)
    const uniqueCategories = [...new Set(allNotas.map((nota) => nota.data.category).filter(Boolean))];
    
    return uniqueCategories.flatMap((categoria) => {
        const filteredNotas = allNotas.filter((nota) => nota.data.category === categoria);
        const sortedNotas = filteredNotas.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());
        
        // We safely URL-encode or lowercase the category for the parameter
        const categorySlug = categoria.toLowerCase().normalize("NFD").replace(/[\u0300-\u036f]/g, "");
        
        return paginate(sortedNotas, {
            params: { categoria: categorySlug },
            props: { originalCategory: categoria },
            pageSize: 6
        });
    });
}

const { page, originalCategory } = Astro.props;
---

<BaseLayout title={`El Pulso: ${originalCategory} - Página ${page.currentPage}`}>
    <main class="flex-grow px-4 md:px-12 py-8 md:py-16 w-full max-w-[1800px] mx-auto">
        <section>
            <!-- Título de la Categoría -->
            <h1 class="text-6xl text-surface font-medium tracking-tighter uppercase mb-12 pb-4 border-b-[8px] border-black">
                {originalCategory}
            </h1>
            
            <!-- Feed de Notas -->
            <div class="flex flex-col divide-y divide-black/20 pb-16">
                {page.data.map(nota => (
                    <article class="py-8 group flex flex-col md:flex-row gap-8 items-start">
                        <a href={`/nota/${nota.slug}`} class="w-full md:w-1/3 shrink-0 overflow-hidden block aspect-[16/9] border border-black/10">
                            <img 
                                src={nota.data.heroImage ? (typeof nota.data.heroImage === 'string' ? nota.data.heroImage : nota.data.heroImage.src) : defaultImg.src} 
                                alt={nota.data.heroImageAlt || nota.data.title} 
                                class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105" 
                            />
                        </a>
                        <div class="flex flex-col flex-grow text-white">
                            <div class="flex items-center gap-3 mb-3">
                                <span class="px-2 py-1 text-xs uppercase tracking-widest text-surface bg-primary">{nota.data.category}</span>
                                <time datetime={nota.data.date} class="text-sm font-semibold uppercase tracking-widest">
                                    {new Date(nota.data.date).toLocaleDateString("es-ES", { year: "numeric", month: "long", day: "numeric" })}
                                </time>
                            </div>
                            <h3 class="text-3xl md:text-4xl font-bold leading-none tracking-tight mb-4">
                                <a href={`/nota/${nota.slug}`} class="hover:text-red-600 transition-colors duration-200">
                                    {nota.data.title}
                                </a>
                            </h3>
                            {nota.data.description && (
                                <p class="text-xl font-medium leading-relaxed mb-6">{nota.data.description}</p>
                            )}
                            
                            <div class="mt-auto">
                                <a href={`/nota/${nota.slug}`}><span class="text-sm font-bold uppercase tracking-widest border-b-2 border-transparent group-hover:border-red-600 transition-colors">Leer Más &rarr;</span></a>
                            </div>
                        </div>
                    </article>
                ))}
            </div>

            <!-- Controles de Paginación -->
            <div class="flex flex-col md:flex-row justify-between items-center mt-8 pt-12 border-t-[8px] border-black gap-6">
                {page.url.prev ? (
                    <a href={page.url.prev} class="group flex items-center justify-center gap-4 border border-white/20 bg-black py-6 px-8 text-lg font-bold uppercase tracking-[0.2em] text-white transition-all duration-300 hover:border-primary hover:bg-primary w-full md:w-auto">
                        <span class="group-hover:hidden">&larr;</span>
                        <span class="hidden group-hover:inline">&rarr;</span>
                        <span>Anterior</span>
                    </a>
                ) : (
                    <span class="flex items-center justify-center gap-4 border border-white/20 bg-black/50 py-6 px-8 text-lg font-bold uppercase tracking-[0.2em] text-white/50 cursor-not-allowed w-full md:w-auto">
                        <span>&larr;</span>
                        <span>Anterior</span>
                    </span>
                )}
                
                <span class="text-xl font-bold font-mono text-white/80">Página <span>{page.currentPage}</span> de <span>{page.lastPage}</span></span>

                {page.url.next ? (
                    <a href={page.url.next} class="group flex items-center justify-center gap-4 border border-white/20 bg-black py-6 px-8 text-lg font-bold uppercase tracking-[0.2em] text-white transition-all duration-300 hover:border-primary hover:bg-primary w-full md:w-auto">
                        <span>Siguiente</span>
                        <span class="group-hover:hidden">&rarr;</span>
                        <span class="hidden group-hover:inline">&larr;</span>
                    </a>
                ) : (
                    <span class="flex items-center justify-center gap-4 border border-white/20 bg-black/50 py-6 px-8 text-lg font-bold uppercase tracking-[0.2em] text-white/50 cursor-not-allowed w-full md:w-auto">
                        <span>Siguiente</span>
                        <span>&rarr;</span>
                    </span>
                )}
            </div>
            
            <!-- Link to entire Feed -->
            <div class="mt-16 w-full pb-8 flex justify-center">
                <a href="/feed" class="inline-block text-lg font-bold uppercase tracking-widest text-black/60 hover:text-primary transition-colors duration-300 border-b-2 border-transparent hover:border-primary">
                    &larr; Volver al feed principal
                </a>
            </div>
        </section>
    </main>
</BaseLayout>
